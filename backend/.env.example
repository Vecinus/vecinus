# --- Configuración de Inteligencia Artificial (Gemini) ---
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# --- Configuración de Base de Datos principal (Supabase) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-or-service-role-key>
SUPABASE_SERVICE_KEY=<service-role-key>
SUPABASE_SCHEMA=dev_S2

# --- Configuración de Base de Datos Vectorial (Pinecone) ---
PINECONE_API_KEY=tu_api_key_de_pinecone_aqui
PINECONE_INDEX_NAME=tu_nombre_de_indice_pinecone_aqui

# --- Configuración de Base de datos de imágenes (Cloudinary) ---
CLOUDINARY_URL=cloudinary://tu_api_key:tu_api_secret@tu_nube_de_cloudinary
# --- Configuración de Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# URL base del frontend (para generar links en emails)
APP_BASE_URL=https://tu-app.com
